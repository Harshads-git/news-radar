# ==============================================
# NEWS RADAR — Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to git!
# ==============================================

# --------------------------------------------------
# AI Provider — Choose ONE (or both for fallback)
# --------------------------------------------------

# Option A: OpenAI (GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=sk-your-openai-key-here

# Option B: Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Option C: Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-key-here

# Which model to use for scoring & summarization
# Options: "gpt-4o-mini", "gemini-1.5-flash", "claude-3-haiku-20240307"
AI_MODEL=gpt-4o-mini

# --------------------------------------------------
# Pipeline Configuration
# --------------------------------------------------

# Minimum score (0–10) to include in briefing
SCORE_THRESHOLD=6

# Output language for AI-generated content
# Options: "English", "Chinese", "Spanish", etc.
OUTPUT_LANGUAGE=English

# Max number of items to include in final briefing
MAX_BRIEFING_ITEMS=20

# --------------------------------------------------
# Delivery Channels (all optional)
# --------------------------------------------------

# Email delivery (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_TO=recipient@example.com

# Discord webhook (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-here

# Slack webhook (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-here

# Generic webhook (optional — any URL that accepts POST JSON)
CUSTOM_WEBHOOK_URL=

# --------------------------------------------------
# Data & Storage
# --------------------------------------------------

# Path to your sources configuration file
SOURCES_FILE=data/sources.json

# Path to store generated briefings
DATA_DIR=data

# --------------------------------------------------
# Logging
# --------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
